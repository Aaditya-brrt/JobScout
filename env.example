# Copy this file to .env for local testing only (never commit the real .env).
# In production (GitHub Actions), these are set as repository Secrets instead -
# see README.md for setup steps.

# Full "cookie" request header value from a logged-in browser session on
# app.joinrunway.io. Expires periodically and needs to be refreshed manually.
RUNWAY_COOKIE=

# Gmail address to send FROM.
GMAIL_ADDRESS=

# Gmail App Password (not your normal password) - generate at
# https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=

# Optional: where to send alerts. Defaults to GMAIL_ADDRESS if unset.
TO_EMAIL=

# Optional: minimum match score to alert on. Defaults to 80 if unset.
MIN_MATCH_SCORE=80
